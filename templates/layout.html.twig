{# templates/layout.html.twig #}

{%- extends 'base.html.twig' -%}

{% block title_head %}
	Title
{% endblock title_head %}
{% block stylesheets %}
	{{ parent() }}
	<style>
		body {
			padding-top: 2rem;
		}
	</style>
{% endblock stylesheets %}
{% block body %}
	<div class="container-fluid">
		<div class="row">
			<div class="col-2">
				<div class="list-group">
					<a href="{{ path('homepage') }}" class="list-group-item list-group-item-action">
						Home
					</a>
					{% if app.user %}
						<a href="{{ path('profile_show') }}" class="list-group-item list-group-item-action">
							{{ app.user.username }}
						</a>
						<a href="{{ path('security_logout') }}" class=" list-group-item list-group-item-action">
							Logout
						</a>
					{% else %}
						<a href="{{ path('security_login') }}" class="list-group-item list-group-item-action">
							Login
						</a>
					{% endif %}
					{% if is_granted('ROLE_ADMIN') %}
						<a href="{{ path('user_index') }}" class="list-group-item list-group-item-action">
							User
						</a>
					{% endif %}
				</div>
			</div>
			<div class="col-10">
				<h1>
					{% block title %}{% endblock title %}
				</h1>
				{% block content %}{% endblock content %}
			</div>
		</div>
	</div>
{% endblock body %}
{% block static %}
	{% if data.isSetEntity %}
		{% include '@MazariniCrud/_delete_form.html.twig' with {'modal_id': 'modalDeleteId'} %}
	{% endif %}
{% endblock static %}
