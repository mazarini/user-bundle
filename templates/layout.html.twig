{# templates/layout.html.twig #}

{%- extends 'base.html.twig' -%}

{% block title_head %}
	Title
{% endblock title_head %}
{% block stylesheets %}
	{{ parent() }}
	<style>
		body {
			padding-top: 2rem;
		}
	</style>
{% endblock stylesheets %}
{% block body %}
	<div class="container-fluid">
		<div class="row">
			<div class="col-2">
				<div class="list-group">
					<a href="{{ path('user_index') }}" class="list-group-item list-group-item-action">
						User
					</a>
					<a href="{{ path('supplier_index') }}" class="list-group-item list-group-item-action">
						Supplier
					</a>
					<a href="{{ path('stat_week') }}" class="list-group-item list-group-item-action">
						Weekly stat
					</a>
				</div>
			</div>
			<div class="col-10">
				<h1>
					{% block title %}{% endblock title %}
				</h1>
				{% block content %}{% endblock content %}
			</div>
		</div>
	</div>
{% endblock body %}
{% block static %}
	{% if data.isSetEntity %}
		{% include '@MazariniCrud/_delete_form.html.twig' with {'modal_id': 'modalDeleteId'} %}
	{% endif %}
{% endblock static %}
