{% extends 'layout.html.twig' %}

{% block title %}
	Change password
{% endblock %}

{% block content %}
<table class="table">
	<tbody>
<tr>
		<th>Username</th>
		<td>{{ data.entity.username }}</td>
	</tr>
	<tr>
		<th>Email</th>
		<td>{{ data.entity.email }}</td>
	</tr>
	<tr>
		<th>Roles</th>
		<td>{{ data.entity.roles ? data.entity.roles|json_encode : '' }}</td>
	</tr>
	<tr>
		<th>Password</th>
		<td>{{ data.entity.password }}</td>
	</tr>
</tbody>
</table>
{% include '@MazariniPagination/_button.html.twig' %}
{% include '@MazariniBootstrap/button/link.html.twig' with { 'link': data.links.change_password } %}
{% endblock content %}
