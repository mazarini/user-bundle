{% extends 'layout.html.twig' %}

{% block head_title %}
	{{ data.entity.username }}
{% endblock head_title %}

{% block title %}
	Profile
	{{ data.entity.username }}
{% endblock title %}

{% block content %}

	{% embed '@MazariniBootstrap/crud/_form.html.twig' with {'data': data } %}

		{% block widget %}
			{{ parent() }}
		{% endblock widget %}

		{% block cancel %}
			{{ parent() }}
		{% endblock cancel %}

		{% block validate %}
			{{ parent() }}
		{% endblock validate %}

	{% endembed %}

{% endblock content %}
