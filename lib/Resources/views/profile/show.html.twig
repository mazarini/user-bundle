{% extends 'layout.html.twig' %}

{% block head_title %}
	{{ data.entity.username }}
{% endblock head_title %}

{% block title %}
	Fiche
	{{ data.entity.username }}
{% endblock title %}

{% block content %}

	{% embed '@MazariniBootstrap/crud/_view.html.twig' with {'data': data } %}

		{% block content %}
			<tr>
				<th>Username</th>
				<td>{{ data.entity.username }}</td>
			</tr>
			<tr>
				<th>Email</th>
				<td>{{ data.entity.email }}</td>
			</tr>
			<tr>
				<th>Roles</th>
				<td>{{ data.entity.roles ? data.entity.roles|json_encode : '' }}</td>
			</tr>
		{% endblock content %}

		{% block edit %}
			{% include '@MazariniBootstrap/button/link.html.twig' with { 'link': entityLink('Mot de passe','_change_password',data.entity) } %}
			{{ parent() }}
		{% endblock edit %}

		{% block delete %}{% endblock delete %}

		{% block back %}
			{{ parent() }}
		{% endblock back %}

	{% endembed %}

{% endblock content %}
